rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow connection test
    match /test/connection {
      allow read: if true;
    }

    // Allow connectivity check
    match /_health/{document=**} {
      allow read: if true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /admin_audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // written by admin SDK server only
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.size() >= 2
          && data.email is string
          && data.updatedAt is number;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (isAdmin() || request.resource.data.role == resource.data.role);

      // 2. Sessions Sub-collection
      match /sessions/{sessionId} {
        function isValidSession(data) {
          return data.size() >= 4
            && data.title is string
            && data.taskType is string
            && data.updatedAt is number;
        }

        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(sessionId) && isValidSession(request.resource.data);
        allow update: if isOwner(userId) && isValidId(sessionId) && isValidSession(request.resource.data)
            && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId) || isAdmin();

        match /versions/{versionId} {
          function isValidVersion(data) {
             return (!data.keys().hasAll(['content']) || (data.content is string && data.content.size() <= 200000));
          }
          allow read: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(versionId) && isValidVersion(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /illustrations/{illustrationId} {
          function isValidIllustration(data) {
             return (!data.keys().hasAll(['status']) || data.status in ['pending', 'approved', 'rejected', 'uploading', 'error']);
          }
          allow read: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(illustrationId) && isValidIllustration(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }

      // 3. Tasks Collection
      match /tasks/{taskId} {
        function isValidWorkTask(data) {
          return data.size() >= 8
            && data.title is string && data.title.size() > 0
            && data.assignee is string
            && data.categoryCode is string
            && data.status is string
            && data.priority is string
            && data.isDeputy is bool
            && data.ownerId == userId // Strict ownership
            && data.updatedAt is number;
        }

        allow read, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidWorkTask(request.resource.data);
        allow update: if isOwner(userId) && isValidWorkTask(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // 4. Documents Sub-collection
      match /documents/{docId} {
        function isValidDocument(data) {
          return data.size() >= 4
            && data.name is string
            && (data.type is string || data.sourceType is string)
            && data.category in ['GENERAL', 'PROJECT'];
        }

        allow read, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidDocument(request.resource.data);
        allow update: if isOwner(userId) && isValidDocument(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // 5. Library Collections Sub-collection
      match /libraryCollections/{collectionId} {
        allow read, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }

      // 6. Settings Sub-collection
      match /settings/aiKey {
        // Block all direct client access to aiKey. Only backend should handle this.
        // Frontend will use /api/user-ai-key/status to check status.
        allow read, write: if false;
      }

      // 7. Profile Sub-collection
      match /profile/{docId} {
        function isValidProfile(data) {
          return (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100)
            && (data.get('title', '') is string && data.get('title', '').size() <= 100)
            && (data.get('department', '') is string && data.get('department', '').size() <= 100)
            && (data.get('phone', '') is string && data.get('phone', '').size() <= 20)
            && (data.get('avatarText', '') is string && data.get('avatarText', '').size() <= 10)
            && (data.get('defaultAssigneeName', '') is string && data.get('defaultAssigneeName', '').size() <= 100)
            && (data.get('defaultTaskCategoryCode', '') is string && data.get('defaultTaskCategoryCode', '').size() <= 50);
        }

        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidProfile(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
      // 9. Chat Attachments Sub-collection
      match /chatAttachments/{attachmentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      // 10. Activity Logs Sub-collection
      match /activityLogs/{logId} {
        allow read, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // 11. Proposals Collection
      match /proposals/{proposalId} {
        allow read, list: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidId(proposalId);
        allow delete: if isOwner(userId) || isAdmin();

        match /sources/{sourceId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(sourceId);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /outlineItems/{itemId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(itemId);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /drafts/{draftId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(draftId);
          allow delete: if isOwner(userId) || isAdmin();

          match /versions/{versionId} {
            allow read, list: if isOwner(userId) || isAdmin();
            allow create: if isOwner(userId) && isValidId(versionId);
            allow update, delete: if isOwner(userId) || isAdmin();
          }
        }

        match /dataTables/{tableId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(tableId);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /comments/{commentId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(commentId);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /exports/{exportId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && isValidId(exportId);
          allow update, delete: if isOwner(userId) || isAdmin();
        }

        match /checklistItems/{itemId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(itemId);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /dataRequirements/{itemId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(itemId);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /evidenceLinks/{linkId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) && isValidId(linkId);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /activityLogs/{logId} {
          allow read, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && isValidId(logId);
          allow update, delete: if false;
        }
      }
    }
  }
}
