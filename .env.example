# FIREBASE CLIENT (VITE)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIRESTORE_DATABASE_ID=ai-studio-b6074ed0-9102-4183-836c-45db24476dce

# FIREBASE ADMIN (SERVER)
FIREBASE_PROJECT_ID=gen-lang-client-0733170002
FIRESTORE_DATABASE_ID=ai-studio-b6074ed0-9102-4183-836c-45db24476dce
FIREBASE_STORAGE_BUCKET=gen-lang-client-0733170002.firebasestorage.app
# Provide service account as JSON string or Base64
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# AI & EXTERNAL APIS
GEMINI_API_KEY=your_gemini_key
GOOGLE_DRIVE_API_KEY=your_google_drive_key
# Optional legacy/system AI key fallback used by backend if GEMINI_API_KEY is absent. Prefer GEMINI_API_KEY for Gemini.
GOOGLE_API_KEY=
AI_KEY_ENCRYPTION_SECRET=your_long_random_secret_for_user_keys

# MODELS
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_PRO_MODEL=gemini-2.5-pro

# ADMIN
ADMIN_EMAILS=admin@example.com

# FEATURE FLAGS
ENABLE_PROPOSAL_API=false
VITE_ENABLE_GOOGLE_AUTH=false
VITE_ENABLE_ANONYMOUS_AUTH=true

# SERVER SECURITY
ALLOWED_ORIGINS=https://your-production-domain.example
ALLOW_CUSTOM_MODELS=false
